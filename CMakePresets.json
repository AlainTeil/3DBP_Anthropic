{
    "version": 6,
    "cmakeMinimumRequired": {
        "major": 3,
        "minor": 20,
        "patch": 0
    },
    "configurePresets": [
        {
            "name": "base",
            "hidden": true,
            "binaryDir": "${sourceDir}/build/${presetName}",
            "cacheVariables": {
                "CMAKE_CXX_STANDARD": "20",
                "CMAKE_EXPORT_COMPILE_COMMANDS": "ON"
            }
        },
        {
            "name": "debug",
            "displayName": "Debug",
            "inherits": "base",
            "cacheVariables": {
                "CMAKE_BUILD_TYPE": "Debug",
                "BP3D_BUILD_TESTS": "ON"
            }
        },
        {
            "name": "release",
            "displayName": "Release",
            "inherits": "base",
            "cacheVariables": {
                "CMAKE_BUILD_TYPE": "Release",
                "BP3D_BUILD_TESTS": "OFF"
            }
        },
        {
            "name": "debug-clang",
            "displayName": "Debug (Clang)",
            "inherits": "debug",
            "cacheVariables": {
                "CMAKE_C_COMPILER": "clang",
                "CMAKE_CXX_COMPILER": "clang++"
            }
        },
        {
            "name": "release-clang",
            "displayName": "Release (Clang)",
            "inherits": "release",
            "cacheVariables": {
                "CMAKE_C_COMPILER": "clang",
                "CMAKE_CXX_COMPILER": "clang++"
            }
        },
        {
            "name": "debug-gcc",
            "displayName": "Debug (GCC)",
            "inherits": "debug",
            "cacheVariables": {
                "CMAKE_C_COMPILER": "gcc",
                "CMAKE_CXX_COMPILER": "g++"
            }
        },
        {
            "name": "release-gcc",
            "displayName": "Release (GCC)",
            "inherits": "release",
            "cacheVariables": {
                "CMAKE_C_COMPILER": "gcc",
                "CMAKE_CXX_COMPILER": "g++"
            }
        },
        {
            "name": "clang-tidy",
            "displayName": "Debug with clang-tidy",
            "inherits": "debug-clang",
            "cacheVariables": {
                "BP3D_ENABLE_CLANG_TIDY": "ON"
            }
        },
        {
            "name": "asan",
            "displayName": "Debug with AddressSanitizer",
            "inherits": "debug-clang",
            "cacheVariables": {
                "BP3D_ENABLE_ASAN": "ON",
                "BP3D_ENABLE_UBSAN": "ON"
            }
        },
        {
            "name": "tsan",
            "displayName": "Debug with ThreadSanitizer",
            "inherits": "debug-clang",
            "cacheVariables": {
                "BP3D_ENABLE_TSAN": "ON"
            }
        }
    ],
    "buildPresets": [
        {
            "name": "debug",
            "configurePreset": "debug"
        },
        {
            "name": "release",
            "configurePreset": "release"
        },
        {
            "name": "debug-clang",
            "configurePreset": "debug-clang"
        },
        {
            "name": "release-clang",
            "configurePreset": "release-clang"
        }
    ],
    "testPresets": [
        {
            "name": "debug",
            "configurePreset": "debug",
            "output": {
                "outputOnFailure": true
            }
        },
        {
            "name": "debug-clang",
            "configurePreset": "debug-clang",
            "output": {
                "outputOnFailure": true
            }
        },
        {
            "name": "clang-tidy",
            "configurePreset": "clang-tidy",
            "output": {
                "outputOnFailure": true
            }
        },
        {
            "name": "asan",
            "configurePreset": "asan",
            "output": {
                "outputOnFailure": true
            }
        },
        {
            "name": "tsan",
            "configurePreset": "tsan",
            "output": {
                "outputOnFailure": true
            }
        }
    ]
}
